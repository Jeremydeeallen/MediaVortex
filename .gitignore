# Claude Code harness ephemera (lock files change every session)
.claude/*.bak
.claude/*.lock
.claude/.session-state.json
.claude/.standards-overrides.log

# Log files
*.log
*.log.cutree
*.err
ffmpeg2pass-*.log
x265_2pass.log*
vmaf_results.json
vmaf_output.xml
vmaf_test_*.xml
Scripts/Smoke/*.results.json
backfill-shard-*

# Pipeline test harness mutable spool (real file backups + Jellyfin capture)
Tests/Pipeline/_backup/*
!Tests/Pipeline/_backup/.gitkeep
Tests/Pipeline/_jellyfin_capture/*
!Tests/Pipeline/_jellyfin_capture/.gitkeep
# Whisper / langdetect models (operator-deployed; not source-controlled)
AIModels/*.bin
whisper_*.jsonl

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.so
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

