{
  "openapi": "3.0.0",
  "info": {
    "title": "Transcode Queue Get API",
    "version": "1.0.0",
    "description": "API contract for retrieving the prioritized transcoding queue"
  },
  "paths": {
    "/api/transcode/queue": {
      "get": {
        "summary": "Get prioritized transcoding queue",
        "description": "Retrieves the transcoding queue ordered by file size (largest first)",
        "operationId": "getTranscodeQueue",
        "responses": {
          "200": {
            "description": "Queue retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueGetResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QueueGetResponse": {
        "type": "object",
        "properties": {
          "Message": {
            "type": "string",
            "description": "Success message"
          },
          "QueueItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QueueItem"
            },
            "description": "List of queue items in new order"
          },
          "TotalItems": {
            "type": "integer",
            "description": "Total number of items in queue"
          },
          "TotalSizeMB": {
            "type": "number",
            "description": "Total size of all items in queue (MB)"
          }
        },
        "required": ["Message", "QueueItems", "TotalItems", "TotalSizeMB"]
      },
      "QueueItem": {
        "type": "object",
        "properties": {
          "Id": {
            "type": "integer",
            "description": "Queue item ID"
          },
          "FilePath": {
            "type": "string",
            "description": "Path to the file"
          },
          "FileName": {
            "type": "string",
            "description": "Name of the file"
          },
          "SizeMB": {
            "type": "number",
            "description": "Size of the file in MB"
          },
          "Status": {
            "type": "string",
            "enum": ["pending", "processing", "completed", "failed"],
            "description": "Current status of the queue item"
          },
          "AssignedProfile": {
            "type": "string",
            "description": "Profile assigned to this item"
          },
          "DateAdded": {
            "type": "string",
            "format": "date-time",
            "description": "When the item was added to queue"
          }
        },
        "required": ["Id", "FilePath", "FileName", "SizeMB", "Status", "AssignedProfile", "DateAdded"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "Error": {
            "type": "string",
            "description": "Error message"
          },
          "ErrorCode": {
            "type": "string",
            "description": "Error code"
          },
          "Timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When the error occurred"
          }
        },
        "required": ["Error", "ErrorCode", "Timestamp"]
      }
    }
  }
}
